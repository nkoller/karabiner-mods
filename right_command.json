{
  "title": "Some bullshit that works for me b/c my down arrow key is next to my spacebar",
  "rules": [
    {
      "description": "Map down_arrow to command when held",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "down_arrow",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "right_command",
              "lazy": true
            }
          ],
          "to_if_alone": [
            {
              "key_code": "down_arrow"
            }
          ]
        }
      ]
    }
  ]
}
